npx lint-staged

# Intentar ejecutar Semgrep local de manera silenciosa si está instalado en el PATH
if command -v semgrep >/dev/null 2>&1; then
  echo "🛡️ [Husky] Detectado Semgrep CLI. Corriendo análisis estático local..."
  npm run security:scan
else
  echo "⚠️ [Husky] Semgrep CLI no está instalado en este sistema. Omitiendo escaneo rápido pre-commit."
  echo "   (Despreocúpate: el pipeline de GitHub con CodeQL auditará la seguridad al subir el código)."
fi
