# ──────────────────────────────────────────────────────────────────────────────
# DATABASE & DATA LAYER
# ──────────────────────────────────────────────────────────────────────────────
# Neon PostgreSQL Connection String (with Connection Pooling enabled for Production)
# Locally, this can point to your local Docker container: postgresql://devuser:devpass@localhost:5432/platform_dev
DATABASE_URL="postgresql://devuser:devpass@localhost:5432/platform_dev"

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY (Auth.js v5)
# ──────────────────────────────────────────────────────────────────────────────
# Run 'npx auth secret' or generate a secure 32-byte key for encryption
AUTH_SECRET="your-super-shared-secret-key"
NEXTAUTH_SECRET="your-super-shared-secret-key"

# GitHub OAuth Provider (Create a developer application on GitHub Settings)
# Callback URL for development: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ──────────────────────────────────────────────────────────────────────────────
# ARTIFICIAL INTELLIGENCE & LLM API KEYS
# ──────────────────────────────────────────────────────────────────────────────
# Google Gemini API Key (Primary Provider - generous free tier)
GEMINI_API_KEY=""

# OpenRouter API Key (Manual Fallback Provider - e.g. Llama 3)
OPENROUTER_API_KEY=""

# Groq API Key (Ultra-fast Inference - generous free tier beta)
GROQ_API_KEY=""

# ──────────────────────────────────────────────────────────────────────────────
# FILE STORAGE (UploadThing)
# ──────────────────────────────────────────────────────────────────────────────
# Generate these secrets in your UploadThing dashboard
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: RATE LIMITING (Upstash Redis)
# ──────────────────────────────────────────────────────────────────────────────
# Required if you implement the sliding-window rate limiter in Server Actions
UPSTASH_REDIS_REST_URL=""
# Upstash REST Token for serverless access
UPSTASH_REDIS_REST_TOKEN=""
