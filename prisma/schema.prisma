datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth v5 Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("developer")
  passwordHash  String?   @db.Text
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  
  // SkillRadar custom relations
  resumes           Resume[]
  jobMatches        JobMatch[]
  githubAnalyses    GithubAnalysis[]
  interviewSessions InterviewSession[]
  receivedRequests  ContactRequest[]   @relation("DeveloperRequests")
  sentRequests      ContactRequest[]   @relation("RecruiterRequests")
  shortlists        Shortlist[]        @relation("RecruiterShortlists")
  shortlistedBy     Shortlist[]        @relation("DeveloperShortlists")
  jobApplications   JobApplication[]

  // Claves de API Personales (Cifradas con AES-256-GCM)
  geminiApiKey       String?   @db.Text
  groqApiKey         String?   @db.Text
  openrouterApiKey   String?   @db.Text
  openaiApiKey       String?   @db.Text
  anthropicApiKey    String?   @db.Text
  
  // Preferencias de Inferencia
  defaultAiProvider  String    @default("gemini") // "gemini" | "groq" | "openrouter" | "openai" | "anthropic"
  defaultAiModel     String    @default("gemini-2.5-flash")

  // Perfil Público Compartible
  isPublicProfile    Boolean   @default(false)
  publicUsername     String?   @unique
  showSkills         Boolean   @default(true)
  showGithub         Boolean   @default(true)
  showSeniority      Boolean   @default(true)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// SkillRadar Custom Models
model Resume {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  fileUrl     String
  rawText     String   @db.Text
  atsScore    Int?
  analysis    Json?    // { keywords: [], missingKeywords: [], formatIssues: [], strengths: [], improvements: [], estimatedSeniority: "" }
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatches  JobMatch[]
}

model JobMatch {
  id           String   @id @default(cuid())
  userId       String
  resumeId     String?
  jobOfferText String   @db.Text
  matchScore   Int?
  analysis     Json?    // { requiredSkills: [], missingSkills: [], seniority: "", recommendations: [] }
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume       Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
}

model GithubAnalysis {
  id           String   @id @default(cuid())
  userId       String
  githubUser   String
  profileScore Int?
  languages    Json?    // { TypeScript: 45, Python: 30, ... }
  repos        Json?    // Array of repo summaries
  activity     Json?    // commits/week, streak, etc
  analysis     Json?    // { strengths: [], weaknesses: [], suggestions: [] }
  createdAt    DateTime @default(now())

  // 18.1: Developer Intelligence Engine — Seniority Signals
  commitFrequency    String?  // "daily" | "weekly" | "sporadic" | "inactive"
  readmeQualityScore Int?     // 0-100
  longestStreakDays  Int?
  topRepoTopics      Json?    // string[]
  senioritySignals   Json?    // string[] — qualitative evidence detected by AI
  detectedPatterns   Json?    // { hasCI, hasTesting, hasDocker, hasAuthImplementation, hasCaching, hasObservability }

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id         String   @id @default(cuid())
  userId     String
  resumeId   String?
  jobMatchId String?
  score      Int?     // Calificación global promedio (0-100)
  debrief    Json?    // Calificaciones estructuradas y feedback cualitativo
  messages   Json     // Historial de la conversación [{ role: "user" | "assistant", content: "" }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id          String   @id @default(cuid())
  recruiterId String
  developerId String
  message     String   @db.Text
  status      String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiter   User     @relation("RecruiterRequests", fields: [recruiterId], references: [id], onDelete: Cascade)
  developer   User     @relation("DeveloperRequests", fields: [developerId], references: [id], onDelete: Cascade)
}

model Shortlist {
  id          String   @id @default(cuid())
  recruiterId String
  developerId String
  createdAt   DateTime @default(now())

  recruiter   User     @relation("RecruiterShortlists", fields: [recruiterId], references: [id], onDelete: Cascade)
  developer   User     @relation("DeveloperShortlists", fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, developerId])
}

model JobApplication {
  id        String   @id @default(cuid())
  userId    String
  title     String
  company   String
  url       String?
  status    String   @default("to_apply") // "to_apply" | "applied" | "interviewing" | "offer"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
